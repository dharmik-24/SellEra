<%- include('../partials/head.ejs') %>

<!-- Order Confirmation Page -->
<main class="min-h-screen bg-neutral-50">
    <!-- Success Header -->
    <section class="bg-gradient-to-r from-green-600 to-green-700 text-white py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center">
                <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-6">
                    <i class="ri-check-line text-4xl text-green-600"></i>
                </div>
                <h1 class="text-3xl md:text-4xl font-bold mb-4">
                    Order Confirmed!
                </h1>
                <p class="text-lg text-green-100">
                    Thank you for your purchase. Your order has been successfully placed.
                </p>
            </div>
        </div>
    </section>

    <!-- Order Details -->
    <section class="py-12">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Order Summary Card -->
            <div class="bg-white rounded-2xl shadow-lg overflow-hidden mb-8">
                <div class="bg-neutral-50 px-6 py-4 border-b border-neutral-200">
                    <div class="flex items-center justify-between">
                        <h2 class="text-xl font-semibold text-neutral-900">Order Details</h2>
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                            <i class="ri-check-line mr-1"></i>Confirmed
                        </span>
                    </div>
                </div>
                
                <div class="p-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                        <div>
                            <h3 class="text-sm font-medium text-neutral-700 mb-2">Order Number</h3>
                            <p class="text-lg font-semibold text-neutral-900">#<%= order._id.toString().slice(-8).toUpperCase() %></p>
                        </div>
                        <div>
                            <h3 class="text-sm font-medium text-neutral-700 mb-2">Order Date</h3>
                            <p class="text-lg font-semibold text-neutral-900"><%= new Date(order.createdAt).toLocaleDateString() %></p>
                        </div>
                        <div>
                            <h3 class="text-sm font-medium text-neutral-700 mb-2">Total Amount</h3>
                            <p class="text-lg font-semibold text-primary-600">₹<%= order.total %></p>
                        </div>
                        <div>
                            <h3 class="text-sm font-medium text-neutral-700 mb-2">Payment Status</h3>
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">
                                <i class="ri-time-line mr-1"></i>Pending
                            </span>
                        </div>
                    </div>

                    <!-- Order Items -->
                    <div class="border-t border-neutral-200 pt-6">
                        <h3 class="text-lg font-semibold text-neutral-900 mb-4">Items Ordered</h3>
                        <div class="space-y-4">
                            <% for(let product of order.orderProducts) { %>
                                <div class="flex items-center space-x-4 p-4 bg-neutral-50 rounded-lg">
                                    <div class="w-16 h-16 bg-neutral-200 rounded-lg flex items-center justify-center">
                                        <% if (product.image && product.image.data) { %>
                                            <img src="data:<%= product.image.contentType %>;base64,<%= product.image.data.toString('base64') %>" 
                                                 alt="<%= product.name %>" class="w-full h-full object-cover rounded-lg">
                                        <% } else { %>
                                            <i class="ri-image-line text-2xl text-neutral-400"></i>
                                        <% } %>
                                    </div>
                                    <div class="flex-1">
                                        <h4 class="font-semibold text-neutral-900"><%= product.name %></h4>
                                        <p class="text-sm text-neutral-600">Category: <%= product.category %></p>
                                        <p class="text-sm text-neutral-600">Quantity: 1</p>
                                    </div>
                                    <div class="text-right">
                                        <p class="font-semibold text-neutral-900">₹<%= product.price %></p>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Order Total Breakdown -->
                    <div class="border-t border-neutral-200 pt-6 mt-6">
                        <div class="space-y-2">
                            <div class="flex justify-between text-neutral-600">
                                <span>Subtotal</span>
                                <span>₹<%= order.subtotal || Math.round(order.total / 1.18) %></span>
                            </div>
                            <div class="flex justify-between text-neutral-600">
                                <span>Shipping</span>
                                <span class="text-green-600">Free</span>
                            </div>
                            <div class="flex justify-between text-neutral-600">
                                <span>Tax (18%)</span>
                                <span>₹<%= order.tax || Math.round(order.total * 0.18 / 1.18) %></span>
                            </div>
                            <div class="flex justify-between text-lg font-bold text-neutral-900 border-t border-neutral-200 pt-2">
                                <span>Total</span>
                                <span class="text-primary-600">₹<%= order.total %></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Shipping Information -->
            <div class="bg-white rounded-2xl shadow-lg overflow-hidden mb-8">
                <div class="bg-neutral-50 px-6 py-4 border-b border-neutral-200">
                    <h2 class="text-xl font-semibold text-neutral-900">Shipping Information</h2>
                </div>
                <div class="p-6">
                    <div class="flex items-start space-x-4">
                        <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center">
                            <i class="ri-truck-line text-primary-600"></i>
                        </div>
                        <div>
                            <h3 class="font-semibold text-neutral-900 mb-2">Delivery Address</h3>
                            <% if (order.shippingAddress) { %>
                                <p class="text-neutral-600">
                                    <%= order.shippingAddress.street %><br>
                                    <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> <%= order.shippingAddress.zipCode %><br>
                                    <%= order.shippingAddress.country %>
                                </p>
                            <% } else { %>
                                <p class="text-neutral-600">
                                    Default shipping address<br>
                                    Will be updated during processing
                                </p>
                            <% } %>
                            <div class="mt-4">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
                                    <i class="ri-time-line mr-1"></i>Estimated delivery: 3-5 business days
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Next Steps -->
            <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
                <div class="bg-neutral-50 px-6 py-4 border-b border-neutral-200">
                    <h2 class="text-xl font-semibold text-neutral-900">What's Next?</h2>
                </div>
                <div class="p-6">
                    <div class="space-y-4">
                        <div class="flex items-center space-x-4">
                            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
                                <i class="ri-check-line text-green-600"></i>
                            </div>
                            <div>
                                <h4 class="font-semibold text-neutral-900">Order Confirmed</h4>
                                <p class="text-sm text-neutral-600">Your order has been received and is being processed</p>
                            </div>
                        </div>
                        
                        <div class="flex items-center space-x-4">
                            <div class="w-8 h-8 bg-yellow-100 rounded-full flex items-center justify-center">
                                <i class="ri-time-line text-yellow-600"></i>
                            </div>
                            <div>
                                <h4 class="font-semibold text-neutral-900">Processing</h4>
                                <p class="text-sm text-neutral-600">We're preparing your items for shipment</p>
                            </div>
                        </div>
                        
                        <div class="flex items-center space-x-4">
                            <div class="w-8 h-8 bg-neutral-100 rounded-full flex items-center justify-center">
                                <i class="ri-truck-line text-neutral-400"></i>
                            </div>
                            <div>
                                <h4 class="font-semibold text-neutral-900">Shipped</h4>
                                <p class="text-sm text-neutral-600">You'll receive tracking information once shipped</p>
                            </div>
                        </div>
                        
                        <div class="flex items-center space-x-4">
                            <div class="w-8 h-8 bg-neutral-100 rounded-full flex items-center justify-center">
                                <i class="ri-home-line text-neutral-400"></i>
                            </div>
                            <div>
                                <h4 class="font-semibold text-neutral-900">Delivered</h4>
                                <p class="text-sm text-neutral-600">Your order will be delivered to your address</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/orders/history" 
                   class="inline-flex items-center justify-center space-x-2 bg-primary-600 hover:bg-primary-700 text-white px-6 py-3 rounded-lg font-semibold transition-all duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2">
                    <i class="ri-file-list-line"></i>
                    <span>View Order History</span>
                </a>
                
                <a href="/products" 
                   class="inline-flex items-center justify-center space-x-2 bg-white border border-neutral-300 text-neutral-700 px-6 py-3 rounded-lg font-semibold hover:bg-neutral-50 transition-all duration-200">
                    <i class="ri-shopping-bag-line"></i>
                    <span>Continue Shopping</span>
                </a>
            </div>
        </div>
    </section>
</main>

<%- include('../partials/footer.ejs') %>
