<%- include('../partials/head.ejs') %>

    <!-- Checkout Page -->
    <main class="min-h-screen bg-neutral-50">
        <!-- Page Header -->
        <section class="bg-gradient-to-r from-primary-600 to-primary-700 text-white py-16">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center">
                    <h1 class="text-3xl md:text-4xl font-bold mb-4">
                        <i class="ri-secure-payment-line mr-3"></i>Secure Checkout
                    </h1>
                    <p class="text-lg text-primary-100">
                        Complete your order securely
                    </p>
                </div>
            </div>
        </section>

        <!-- Checkout Content -->
        <section class="py-12">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    <!-- Checkout Form -->
                    <div class="lg:col-span-2">
                        <form action="/orders/create" method="POST" class="space-y-8">
                            <!-- Shipping Information -->
                            <div class="bg-white rounded-2xl shadow-lg p-6">
                                <h3 class="text-xl font-semibold text-neutral-900 mb-6 flex items-center">
                                    <i class="ri-truck-line mr-2 text-primary-600"></i>
                                    Shipping Information
                                </h3>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div>
                                        <label for="firstName" class="block text-sm font-medium text-neutral-700 mb-2">
                                            First Name *
                                        </label>
                                        <input type="text" id="firstName" name="shipping[firstName]" required
                                            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                                    </div>

                                    <div>
                                        <label for="lastName" class="block text-sm font-medium text-neutral-700 mb-2">
                                            Last Name *
                                        </label>
                                        <input type="text" id="lastName" name="shipping[lastName]" required
                                            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                                    </div>

                                    <div class="md:col-span-2">
                                        <label for="street" class="block text-sm font-medium text-neutral-700 mb-2">
                                            Street Address *
                                        </label>
                                        <input type="text" id="street" name="shipping[street]" required
                                            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                                    </div>

                                    <div>
                                        <label for="city" class="block text-sm font-medium text-neutral-700 mb-2">
                                            City *
                                        </label>
                                        <input type="text" id="city" name="shipping[city]" required
                                            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                                    </div>

                                    <div>
                                        <label for="state" class="block text-sm font-medium text-neutral-700 mb-2">
                                            State *
                                        </label>
                                        <input type="text" id="state" name="shipping[state]" required
                                            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                                    </div>

                                    <div>
                                        <label for="zipCode" class="block text-sm font-medium text-neutral-700 mb-2">
                                            ZIP Code *
                                        </label>
                                        <input type="text" id="zipCode" name="shipping[zipCode]" required
                                            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                                    </div>

                                    <div>
                                        <label for="country" class="block text-sm font-medium text-neutral-700 mb-2">
                                            Country *
                                        </label>
                                        <select id="country" name="shipping[country]" required
                                            class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                                            <option value="India">India</option>
                                            <option value="USA">United States</option>
                                            <option value="UK">United Kingdom</option>
                                            <option value="Canada">Canada</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Payment Information -->
                            <div class="bg-white rounded-2xl shadow-lg p-6">
                                <h3 class="text-xl font-semibold text-neutral-900 mb-6 flex items-center">
                                    <i class="ri-bank-card-line mr-2 text-primary-600"></i>
                                    Payment Information
                                </h3>

                                <div class="space-y-6">
                                    <div>
                                        <label class="block text-sm font-medium text-neutral-700 mb-4">
                                            Payment Method
                                        </label>
                                        <div class="space-y-3">
                                            <label
                                                class="flex items-center p-4 border border-neutral-300 rounded-lg cursor-pointer hover:bg-neutral-50 transition-colors duration-200">
                                                <input type="radio" name="paymentMethod" value="card" class="mr-3"
                                                    checked>
                                                <i class="ri-bank-card-line mr-2 text-primary-600"></i>
                                                <span>Credit/Debit Card</span>
                                            </label>
                                            <label
                                                class="flex items-center p-4 border border-neutral-300 rounded-lg cursor-pointer hover:bg-neutral-50 transition-colors duration-200">
                                                <input type="radio" name="paymentMethod" value="upi" class="mr-3">
                                                <i class="ri-smartphone-line mr-2 text-primary-600"></i>
                                                <span>UPI Payment</span>
                                            </label>
                                            <label
                                                class="flex items-center p-4 border border-neutral-300 rounded-lg cursor-pointer hover:bg-neutral-50 transition-colors duration-200">
                                                <input type="radio" name="paymentMethod" value="cod" class="mr-3">
                                                <i class="ri-money-rupee-circle-line mr-2 text-primary-600"></i>
                                                <span>Cash on Delivery</span>
                                            </label>
                                        </div>
                                    </div>

                                    <div id="cardDetails" class="space-y-4">
                                        <div>
                                            <label for="cardNumber"
                                                class="block text-sm font-medium text-neutral-700 mb-2">
                                                Card Number
                                            </label>
                                            <input type="text" id="cardNumber" placeholder="1234 5678 9012 3456"
                                                class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                                        </div>

                                        <div class="grid grid-cols-2 gap-4">
                                            <div>
                                                <label for="expiryDate"
                                                    class="block text-sm font-medium text-neutral-700 mb-2">
                                                    Expiry Date
                                                </label>
                                                <input type="text" id="expiryDate" placeholder="MM/YY"
                                                    class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                                            </div>

                                            <div>
                                                <label for="cvv"
                                                    class="block text-sm font-medium text-neutral-700 mb-2">
                                                    CVV
                                                </label>
                                                <input type="text" id="cvv" placeholder="123"
                                                    class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Place Order Button -->
                            <div class="bg-white rounded-2xl shadow-lg p-6">
                                <button type="submit"
                                    class="w-full bg-primary-600 hover:bg-primary-700 text-white py-4 px-6 rounded-lg font-semibold text-lg transition-all duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 shadow-lg hover:shadow-xl">
                                    <i class="ri-secure-payment-line mr-2"></i>Place Order Securely
                                </button>

                                <div class="mt-4 text-center">
                                    <div class="flex items-center justify-center space-x-2 text-sm text-neutral-600">
                                        <i class="ri-shield-check-line text-green-600"></i>
                                        <span>Your payment information is secure and encrypted</span>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>

                    <!-- Order Summary -->
                    <div class="lg:col-span-1">
                        <div class="bg-white rounded-2xl shadow-lg p-6 sticky top-6">
                            <h3 class="text-xl font-semibold text-neutral-900 mb-6">Order Summary</h3>

                            <!-- Cart Items Summary -->
                            <div class="space-y-4 mb-6">
                                <% if(products && products.length> 0) { %>
                                    <% for(let item of products) { %>
                                        <div class="flex items-center space-x-3">
                                            <div
                                                class="w-12 h-12 bg-neutral-200 rounded-lg flex items-center justify-center overflow-hidden">
                                                <% if (typeof getProductImageUrl !=='undefined' && item.product) { %>
                                                    <% const checkoutImageUrl=getProductImageUrl(item.product); const
                                                        checkoutIsDefaultImage=checkoutImageUrl==='/images/default.jpg'
                                                        ; %>
                                                        <% if (!checkoutIsDefaultImage) { %>
                                                            <img src="<%= checkoutImageUrl %>"
                                                                alt="<%= item.product.name %>"
                                                                class="w-full h-full object-cover">
                                                            <% } else { %>
                                                                <i class="ri-image-line text-neutral-400"></i>
                                                                <% } %>
                                                                    <% } else { %>
                                                                        <i class="ri-image-line text-neutral-400"></i>
                                                                        <% } %>
                                            </div>
                                            <div class="flex-1">
                                                <h4 class="font-medium text-neutral-900">
                                                    <%= item.product.name %>
                                                </h4>
                                                <p class="text-sm text-neutral-600">Qty: <%= item.quantity %>
                                                </p>
                                            </div>
                                            <span class="font-semibold text-neutral-900">₹<%= item.product.price *
                                                    item.quantity %></span>
                                        </div>
                                        <% } %>
                                            <% } %>
                            </div>

                            <!-- Order Totals -->
                            <div class="space-y-3 border-t border-neutral-200 pt-4">
                                <div class="flex justify-between text-neutral-600">
                                    <span>Subtotal</span>
                                    <span>₹<%= total %></span>
                                </div>
                                <div class="flex justify-between text-neutral-600">
                                    <span>Shipping</span>
                                    <span class="text-green-600">Free</span>
                                </div>
                                <div class="flex justify-between text-neutral-600">
                                    <span>Tax (18%)</span>
                                    <span>₹<%= Math.round(total * 0.18) %></span>
                                </div>
                                <div
                                    class="flex justify-between text-lg font-bold text-neutral-900 border-t border-neutral-200 pt-3">
                                    <span>Total</span>
                                    <span class="text-primary-600">₹<%= Math.round(total * 1.18) %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        // Payment method toggle
        const paymentMethods = document.querySelectorAll('input[name="paymentMethod"]');
        const cardDetails = document.getElementById('cardDetails');

        paymentMethods.forEach(method => {
            method.addEventListener('change', function () {
                if (this.value === 'card') {
                    cardDetails.style.display = 'block';
                } else {
                    cardDetails.style.display = 'none';
                }
            });
        });
    </script>

    <%- include('../partials/footer.ejs') %>