<%- include('../partials/head.ejs') %>

    <!-- Shopping Cart Page -->
    <main class="min-h-screen bg-neutral-50">
        <!-- Page Header -->
        <section class="bg-gradient-to-r from-primary-600 to-primary-700 text-white py-16">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center">
                    <h1 class="text-3xl md:text-4xl font-bold mb-4">
                        <i class="ri-shopping-cart-line mr-3"></i>Shopping Cart
                    </h1>
                    <p class="text-lg text-primary-100">
                        Review your selected items before checkout
                    </p>
                </div>
            </div>
        </section>

        <% if(products && products.length> 0){ %>
            <!-- Cart Content -->
            <section class="py-12">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                        <!-- Cart Items -->
                        <div class="lg:col-span-2">
                            <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
                                <!-- Cart Header - Desktop Only -->
                                <div class="hidden md:block bg-neutral-50 px-6 py-4 border-b border-neutral-200">
                                    <div class="grid grid-cols-12 gap-4 text-sm font-semibold text-neutral-700">
                                        <div class="col-span-6">Product</div>
                                        <div class="col-span-2 text-center">Quantity</div>
                                        <div class="col-span-2 text-center">Price</div>
                                        <div class="col-span-2 text-center">Total</div>
                                    </div>
                                </div>

                                <!-- Cart Items -->
                                <div class="divide-y divide-neutral-200">
                                    <% for(let i of products){ %>
                                        <!-- Desktop Layout -->
                                        <div class="hidden md:block p-6">
                                            <div class="grid grid-cols-12 gap-4 items-center">
                                                <!-- Product Info -->
                                                <div class="col-span-6">
                                                    <div class="flex items-center space-x-4">
                                                        <div
                                                            class="w-16 h-16 bg-neutral-200 rounded-lg flex items-center justify-center flex-shrink-0 overflow-hidden">
                                                            <% const imageUrl=getProductImageUrl(i.product); const
                                                                isDefaultImage=imageUrl==='/images/default.jpg' ; %>
                                                                <% if (!isDefaultImage) { %>
                                                                    <img src="<%= imageUrl %>"
                                                                        alt="<%= i.product.name %>"
                                                                        class="w-full h-full object-cover">
                                                                    <% } else { %>
                                                                        <i
                                                                            class="ri-image-line text-2xl text-neutral-400"></i>
                                                                        <% } %>
                                                        </div>
                                                        <div class="min-w-0">
                                                            <h3 class="font-semibold text-neutral-900 mb-1 truncate">
                                                                <%= i.product.name %>
                                                            </h3>
                                                            <p class="text-sm text-neutral-600">
                                                                Category: <%= i.product.category || 'General' %>
                                                            </p>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Quantity -->
                                                <div class="col-span-2">
                                                    <div class="flex items-center justify-center space-x-2">
                                                        <form action="/users/cart/<%= i.product._id %>?_method=PATCH"
                                                            method="POST" class="inline">
                                                            <input type="hidden" name="quantity"
                                                                value="<%= Math.max(1, i.quantity - 1) %>">
                                                            <button type="submit" <% if(i.quantity <=1) { %>disabled<% }
                                                                    %>
                                                                    class="w-8 h-8 bg-neutral-100 hover:bg-neutral-200
                                                                    disabled:opacity-50 disabled:cursor-not-allowed
                                                                    rounded-full flex items-center justify-center
                                                                    transition-colors duration-200">
                                                                    <i class="ri-subtract-line text-sm"></i>
                                                            </button>
                                                        </form>
                                                        <span class="w-12 text-center font-semibold">
                                                            <%= i.quantity %>
                                                        </span>
                                                        <form action="/users/cart/<%= i.product._id %>?_method=PATCH"
                                                            method="POST" class="inline">
                                                            <input type="hidden" name="quantity"
                                                                value="<%= i.quantity + 1 %>">
                                                            <button type="submit"
                                                                class="w-8 h-8 bg-neutral-100 hover:bg-neutral-200 rounded-full flex items-center justify-center transition-colors duration-200">
                                                                <i class="ri-add-line text-sm"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>

                                                <!-- Price -->
                                                <div class="col-span-2 text-center">
                                                    <span class="font-semibold text-neutral-900">
                                                        ₹<%= i.product.price %>
                                                    </span>
                                                </div>

                                                <!-- Total -->
                                                <div class="col-span-2 text-center">
                                                    <div class="flex items-center justify-center space-x-2">
                                                        <span class="font-bold text-primary-600">
                                                            ₹<%= i.product.price * i.quantity %>
                                                        </span>
                                                        <form action="/users/cart/<%= i.product._id %>?_method=DELETE"
                                                            method="POST" class="inline">
                                                            <button type="submit"
                                                                onclick="return confirm('Remove this item from cart?')"
                                                                class="text-red-500 hover:text-red-700 transition-colors duration-200">
                                                                <i class="ri-delete-bin-line"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Mobile Layout -->
                                        <div class="md:hidden p-4">
                                            <div class="space-y-4">
                                                <!-- Product Info -->
                                                <div class="flex items-start space-x-3">
                                                    <div
                                                        class="w-16 h-16 bg-neutral-200 rounded-lg flex items-center justify-center flex-shrink-0 overflow-hidden">
                                                        <% const mobileImageUrl=getProductImageUrl(i.product); const
                                                            mobileIsDefaultImage=mobileImageUrl==='/images/default.jpg'
                                                            ; %>
                                                            <% if (!mobileIsDefaultImage) { %>
                                                                <img src="<%= mobileImageUrl %>"
                                                                    alt="<%= i.product.name %>"
                                                                    class="w-full h-full object-cover">
                                                                <% } else { %>
                                                                    <i
                                                                        class="ri-image-line text-xl text-neutral-400"></i>
                                                                    <% } %>
                                                    </div>
                                                    <div class="flex-1 min-w-0">
                                                        <h3 class="font-semibold text-neutral-900 mb-1 text-sm">
                                                            <%= i.product.name %>
                                                        </h3>
                                                        <p class="text-xs text-neutral-600 mb-2">
                                                            Category: <%= i.product.category || 'General' %>
                                                        </p>
                                                        <div class="text-sm font-semibold text-neutral-900">
                                                            ₹<%= i.product.price %> each
                                                        </div>
                                                    </div>
                                                    <!-- Remove Button -->
                                                    <form action="/users/cart/<%= i.product._id %>?_method=DELETE"
                                                        method="POST" class="inline">
                                                        <button type="submit"
                                                            onclick="return confirm('Remove this item from cart?')"
                                                            class="text-red-500 hover:text-red-700 transition-colors duration-200 p-1">
                                                            <i class="ri-delete-bin-line text-lg"></i>
                                                        </button>
                                                    </form>
                                                </div>

                                                <!-- Quantity and Total -->
                                                <div class="flex items-center justify-between">
                                                    <!-- Quantity Controls -->
                                                    <div class="flex items-center space-x-3">
                                                        <span class="text-sm font-medium text-neutral-700">Qty:</span>
                                                        <div class="flex items-center space-x-2">
                                                            <form
                                                                action="/users/cart/<%= i.product._id %>?_method=PATCH"
                                                                method="POST" class="inline">
                                                                <input type="hidden" name="quantity"
                                                                    value="<%= Math.max(1, i.quantity - 1) %>">
                                                                <button type="submit" <% if(i.quantity <=1) { %>disabled
                                                                    <% } %>
                                                                        class="w-8 h-8 bg-neutral-100
                                                                        hover:bg-neutral-200
                                                                        disabled:opacity-50 disabled:cursor-not-allowed
                                                                        rounded-full flex items-center justify-center
                                                                        transition-colors duration-200">
                                                                        <i class="ri-subtract-line text-sm"></i>
                                                                </button>
                                                            </form>
                                                            <span class="w-8 text-center font-semibold text-sm">
                                                                <%= i.quantity %>
                                                            </span>
                                                            <form
                                                                action="/users/cart/<%= i.product._id %>?_method=PATCH"
                                                                method="POST" class="inline">
                                                                <input type="hidden" name="quantity"
                                                                    value="<%= i.quantity + 1 %>">
                                                                <button type="submit"
                                                                    class="w-8 h-8 bg-neutral-100 hover:bg-neutral-200 rounded-full flex items-center justify-center transition-colors duration-200">
                                                                    <i class="ri-add-line text-sm"></i>
                                                                </button>
                                                            </form>
                                                        </div>
                                                    </div>

                                                    <!-- Total Price -->
                                                    <div class="text-right">
                                                        <div class="text-xs text-neutral-600 mb-1">Total</div>
                                                        <div class="font-bold text-primary-600 text-lg">
                                                            ₹<%= i.product.price * i.quantity %>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <% } %>
                                </div>
                            </div>

                            <!-- Continue Shopping -->
                            <div class="mt-6">
                                <a href="/products"
                                    class="inline-flex items-center space-x-2 text-primary-600 hover:text-primary-700 font-medium transition-colors duration-200">
                                    <i class="ri-arrow-left-line"></i>
                                    <span>Continue Shopping</span>
                                </a>
                            </div>
                        </div>

                        <!-- Order Summary -->
                        <div class="lg:col-span-1">
                            <div class="bg-white rounded-2xl shadow-lg p-4 sm:p-6 lg:sticky lg:top-24">
                                <h3 class="text-lg sm:text-xl font-bold text-neutral-900 mb-4 sm:mb-6">Order Summary
                                </h3>

                                <div class="space-y-3 sm:space-y-4 mb-4 sm:mb-6">
                                    <div class="flex justify-between text-sm sm:text-base text-neutral-600">
                                        <span>Subtotal (<%= products.length %> items)</span>
                                        <span>₹<%= total %></span>
                                    </div>
                                    <div class="flex justify-between text-sm sm:text-base text-neutral-600">
                                        <span>Shipping</span>
                                        <span class="text-green-600">Free</span>
                                    </div>
                                    <div class="flex justify-between text-sm sm:text-base text-neutral-600">
                                        <span>Tax</span>
                                        <span>₹<%= Math.round(total * 0.18) %></span>
                                    </div>
                                    <div class="border-t border-neutral-200 pt-3 sm:pt-4">
                                        <div
                                            class="flex justify-between text-base sm:text-lg font-bold text-neutral-900">
                                            <span>Total</span>
                                            <span class="text-primary-600">₹<%= Math.round(total * 1.18) %></span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Promo Code -->
                                <div class="mb-4 sm:mb-6">
                                    <div class="flex flex-col sm:flex-row space-y-2 sm:space-y-0 sm:space-x-2">
                                        <input type="text" placeholder="Promo code"
                                            class="flex-1 px-3 py-2 text-sm sm:text-base border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                                        <button
                                            class="px-4 py-2 bg-neutral-100 hover:bg-neutral-200 text-neutral-700 rounded-lg font-medium text-sm sm:text-base transition-colors duration-200 whitespace-nowrap">
                                            Apply
                                        </button>
                                    </div>
                                </div>

                                <!-- Checkout Button -->
                                <form action="/orders/create" method="POST">
                                    <button type="submit"
                                        class="w-full bg-primary-600 hover:bg-primary-700 text-white py-3 px-4 rounded-lg font-semibold text-sm sm:text-base transition-all duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 shadow-lg hover:shadow-xl">
                                        <i class="ri-secure-payment-line mr-2"></i>Proceed to Checkout
                                    </button>
                                </form>

                                <!-- Security Badge -->
                                <div class="mt-3 sm:mt-4 text-center">
                                    <div
                                        class="flex items-center justify-center space-x-2 text-xs sm:text-sm text-neutral-600">
                                        <i class="ri-shield-check-line text-green-600"></i>
                                        <span>Secure checkout guaranteed</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <% } else { %>
                <!-- Empty Cart -->
                <section class="py-20">
                    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                        <div class="text-center">
                            <div
                                class="w-32 h-32 bg-neutral-200 rounded-full flex items-center justify-center mx-auto mb-8">
                                <i class="ri-shopping-cart-line text-6xl text-neutral-400"></i>
                            </div>
                            <h2 class="text-2xl font-bold text-neutral-900 mb-4">Your cart is empty</h2>
                            <p class="text-neutral-600 mb-8 max-w-md mx-auto">
                                Looks like you haven't added any items to your cart yet. Start shopping to fill it up!
                            </p>
                            <a href="/products"
                                class="inline-flex items-center space-x-2 bg-primary-600 hover:bg-primary-700 text-white px-8 py-3 rounded-lg font-semibold transition-all duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2">
                                <i class="ri-shopping-bag-line"></i>
                                <span>Start Shopping</span>
                            </a>
                        </div>
                    </div>
                </section>
                <% } %>
    </main>

    <%- include('../partials/footer.ejs') %>