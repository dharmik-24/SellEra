<%- include('../partials/head.ejs') %>

    <!-- User Profile Content -->
    <div class="min-h-screen bg-gradient-to-br from-primary-50 via-white to-primary-100 py-12">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Profile Header -->
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-neutral-200">
                <!-- Cover Background -->
                <div class="h-32 bg-gradient-to-r from-primary-600 to-primary-700"></div>

                <!-- Profile Info -->
                <div class="relative px-6 pb-6">
                    <!-- Profile Picture -->
                    <div class="flex items-end justify-between -mt-16 mb-4">
                        <div class="relative">
                            <% const profileImageUrl=getProfileImageUrl(user); const
                                isDefaultImage=profileImageUrl==='/images/default.jpg' ; %>
                                <% if (!isDefaultImage) { %>
                                    <img src="<%= profileImageUrl %>" alt="<%= user.name %>"
                                        class="w-32 h-32 rounded-full border-4 border-white shadow-lg object-cover">
                                    <% } else { %>
                                        <div
                                            class="w-32 h-32 rounded-full border-4 border-white shadow-lg bg-primary-600 flex items-center justify-center">
                                            <span class="text-4xl font-bold text-white">
                                                <%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
                                            </span>
                                        </div>
                                        <% } %>
                                            <div
                                                class="absolute bottom-2 right-2 w-6 h-6 bg-green-500 rounded-full border-2 border-white">
                                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="flex space-x-3 mt-16">
                            <a href="/users/edit"
                                class="inline-flex items-center space-x-2 bg-primary-600 hover:bg-primary-700 text-white px-4 py-2 rounded-lg font-medium transition-all duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2">
                                <i class="ri-edit-line"></i>
                                <span>Edit Profile</span>
                            </a>
                            <button onclick="toggleDeleteModal()"
                                class="inline-flex items-center space-x-2 bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg font-medium transition-all duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2">
                                <i class="ri-delete-bin-line"></i>
                                <span>Delete Account</span>
                            </button>
                        </div>
                    </div>

                    <!-- User Details -->
                    <div class="space-y-2">
                        <h1 class="text-3xl font-bold text-neutral-900">
                            <%= user.name || 'User Name' %>
                        </h1>
                        <p class="text-neutral-600 flex items-center">
                            <i class="ri-mail-line mr-2 text-primary-600"></i>
                            <%= user.email %>
                        </p>
                        <p class="text-sm text-neutral-500 flex items-center">
                            <i class="ri-calendar-line mr-2 text-primary-600"></i>
                            Member since <%= new Date().getFullYear() %>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Profile Details Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-8">
                <!-- Personal Information -->
                <div class="lg:col-span-2 space-y-6">
                    <!-- About Section -->
                    <div class="bg-white rounded-xl shadow-lg p-6 border border-neutral-200">
                        <h3 class="text-lg font-semibold text-neutral-900 mb-4 flex items-center">
                            <i class="ri-user-line mr-2 text-primary-600"></i>
                            About Me
                        </h3>
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-neutral-700 mb-1">Full Name</label>
                                <p class="text-neutral-900 bg-neutral-50 px-4 py-3 rounded-lg">
                                    <%= user.name || 'Not provided' %>
                                </p>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-neutral-700 mb-1">Email Address</label>
                                <p class="text-neutral-900 bg-neutral-50 px-4 py-3 rounded-lg flex items-center">
                                    <i class="ri-mail-line mr-2 text-primary-600"></i>
                                    <%= user.email %>
                                </p>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-neutral-700 mb-1">Description</label>
                                <p class="text-neutral-900 bg-neutral-50 px-4 py-3 rounded-lg min-h-[100px]">
                                    <%= user.description
                                        || 'No description provided yet. Click "Edit Profile" to add a description about yourself.'
                                        %>
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Activity Section -->
                    <div class="bg-white rounded-xl shadow-lg p-6 border border-neutral-200">
                        <h3 class="text-lg font-semibold text-neutral-900 mb-4 flex items-center">
                            <i class="ri-history-line mr-2 text-primary-600"></i>
                            Recent Activity
                        </h3>
                        <div class="space-y-4">
                            <div class="flex items-center space-x-3 p-3 bg-neutral-50 rounded-lg">
                                <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
                                    <i class="ri-shopping-cart-line text-green-600"></i>
                                </div>
                                <div class="flex-1">
                                    <p class="text-sm font-medium text-neutral-900">Recent Purchase</p>
                                    <p class="text-xs text-neutral-500">No recent purchases</p>
                                </div>
                            </div>
                            <div class="flex items-center space-x-3 p-3 bg-neutral-50 rounded-lg">
                                <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                                    <i class="ri-star-line text-blue-600"></i>
                                </div>
                                <div class="flex-1">
                                    <p class="text-sm font-medium text-neutral-900">Reviews Given</p>
                                    <p class="text-xs text-neutral-500">No reviews yet</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sidebar -->
                <div class="space-y-6">
                    <!-- Quick Stats -->
                    <div class="bg-white rounded-xl shadow-lg p-6 border border-neutral-200">
                        <h3 class="text-lg font-semibold text-neutral-900 mb-4 flex items-center">
                            <i class="ri-bar-chart-line mr-2 text-primary-600"></i>
                            Quick Stats
                        </h3>
                        <div class="space-y-4">
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-neutral-600">Total Orders</span>
                                <span class="text-lg font-semibold text-primary-600">
                                    <%= userStats.totalOrders %>
                                </span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-neutral-600">Reviews Given</span>
                                <span class="text-lg font-semibold text-primary-600">
                                    <%= userStats.reviewsGiven %>
                                </span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-neutral-600">Cart Items</span>
                                <span class="text-lg font-semibold text-primary-600">
                                    <%= userStats.wishlistItems %>
                                </span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-neutral-600">Account Age</span>
                                <span class="text-lg font-semibold text-primary-600">
                                    <%= userStats.accountAge %> days
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Quick Actions -->
                    <div class="bg-white rounded-xl shadow-lg p-6 border border-neutral-200">
                        <h3 class="text-lg font-semibold text-neutral-900 mb-4 flex items-center">
                            <i class="ri-flashlight-line mr-2 text-primary-600"></i>
                            Quick Actions
                        </h3>
                        <div class="space-y-3">
                            <a href="/users/show-cart"
                                class="flex items-center space-x-3 p-3 bg-neutral-50 hover:bg-primary-50 rounded-lg transition-colors duration-200 group">
                                <i class="ri-shopping-cart-line text-neutral-600 group-hover:text-primary-600"></i>
                                <span class="text-sm font-medium text-neutral-900">View Cart</span>
                            </a>
                            <a href="/products"
                                class="flex items-center space-x-3 p-3 bg-neutral-50 hover:bg-primary-50 rounded-lg transition-colors duration-200 group">
                                <i class="ri-shopping-bag-line text-neutral-600 group-hover:text-primary-600"></i>
                                <span class="text-sm font-medium text-neutral-900">Browse Products</span>
                            </a>
                            <a href="/orders/history"
                                class="flex items-center space-x-3 p-3 bg-neutral-50 hover:bg-primary-50 rounded-lg transition-colors duration-200 group">
                                <i class="ri-file-list-line text-neutral-600 group-hover:text-primary-600"></i>
                                <span class="text-sm font-medium text-neutral-900">Order History</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Account Modal -->
    <div id="deleteModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl max-w-md w-full p-6">
            <div class="flex items-center justify-center w-12 h-12 bg-red-100 rounded-full mx-auto mb-4">
                <i class="ri-error-warning-line text-2xl text-red-600"></i>
            </div>
            <h3 class="text-lg font-semibold text-neutral-900 text-center mb-2">Delete Account</h3>
            <p class="text-neutral-600 text-center mb-6">
                Are you sure you want to delete your account? This action cannot be undone and all your data will be
                permanently removed.
            </p>
            <div class="flex space-x-3">
                <button onclick="toggleDeleteModal()"
                    class="flex-1 px-4 py-2 border border-neutral-300 text-neutral-700 rounded-lg font-medium hover:bg-neutral-50 transition-all duration-200">
                    Cancel
                </button>
                <form action="/users?_method=delete" method="post" class="flex-1">
                    <button type="submit"
                        class="w-full px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg font-medium transition-all duration-200">
                        Delete Account
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script>
        function toggleDeleteModal() {
            const modal = document.getElementById('deleteModal');
            modal.classList.toggle('hidden');
        }

        // Close modal when clicking outside
        document.getElementById('deleteModal').addEventListener('click', function (e) {
            if (e.target === this) {
                toggleDeleteModal();
            }
        });
    </script>

    <%- include('../partials/footer.ejs') %>