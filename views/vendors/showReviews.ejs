<%- include('../partials/vendorHead.ejs') %>

    <script>
        setPageTitle('Customer Reviews');
    </script>

    <!-- Reviews Management Content -->
    <div class="space-y-6">
        <!-- Page Header -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-2xl font-bold text-neutral-900">Customer Reviews</h1>
                <p class="text-neutral-600 mt-1">See what customers are saying about your products</p>
            </div>
            <div class="mt-4 sm:mt-0 flex space-x-3">
                <button
                    class="inline-flex items-center space-x-2 bg-white border border-neutral-300 text-neutral-700 px-4 py-2 rounded-lg font-medium hover:bg-neutral-50 transition-all duration-200">
                    <i class="ri-download-line"></i>
                    <span>Export Reviews</span>
                </button>
            </div>
        </div>

        <% if(reviewArray && reviewArray.length> 0){ %>
            <!-- Reviews Stats -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-white rounded-xl shadow-lg p-6 border border-neutral-200">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-neutral-600 mb-1">Total Reviews</p>
                            <p class="text-2xl font-bold text-neutral-900">
                                <%= reviewArray.length %>
                            </p>
                        </div>
                        <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                            <i class="ri-chat-3-line text-xl text-blue-600"></i>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow-lg p-6 border border-neutral-200">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-neutral-600 mb-1">Average Rating</p>
                            <p class="text-2xl font-bold text-yellow-600">4.5</p>
                        </div>
                        <div class="w-10 h-10 bg-yellow-100 rounded-lg flex items-center justify-center">
                            <i class="ri-star-line text-xl text-yellow-600"></i>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow-lg p-6 border border-neutral-200">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-neutral-600 mb-1">Response Rate</p>
                            <p class="text-2xl font-bold text-green-600">85%</p>
                        </div>
                        <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                            <i class="ri-reply-line text-xl text-green-600"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Reviews List -->
            <div class="bg-white rounded-xl shadow-lg border border-neutral-200">
                <div class="px-6 py-4 border-b border-neutral-200 bg-neutral-50">
                    <h3 class="text-lg font-semibold text-neutral-900">All Reviews (<%= reviewArray.length %>)</h3>
                </div>

                <div class="divide-y divide-neutral-200">
                    <% for (let i of reviewArray) {%>
                        <div class="p-6 hover:bg-neutral-50 transition-colors duration-200">
                            <div class="flex items-start space-x-4">
                                <!-- Customer Avatar -->
                                <div
                                    class="w-12 h-12 bg-primary-600 rounded-full flex items-center justify-center flex-shrink-0">
                                    <span class="text-white font-semibold text-lg">
                                        <%= i.user.name.charAt(0).toUpperCase() %>
                                    </span>
                                </div>

                                <!-- Review Content -->
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center justify-between mb-2">
                                        <div>
                                            <h4 class="text-sm font-semibold text-neutral-900">
                                                <%= i.user.name %>
                                            </h4>
                                            <p class="text-sm text-neutral-500">Verified Customer</p>
                                        </div>
                                        <div class="flex items-center space-x-1">
                                            <% for(let star=1; star <=5; star++) { %>
                                                <i class="ri-star-fill text-yellow-400 text-sm"></i>
                                                <% } %>
                                                    <span class="text-sm text-neutral-600 ml-2">5.0</span>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <p class="text-neutral-700 leading-relaxed">
                                            <%= i.review %>
                                        </p>
                                    </div>

                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center space-x-4 text-sm text-neutral-500">
                                            <span class="flex items-center">
                                                <i class="ri-calendar-line mr-1"></i>
                                                <%= new Date().toLocaleDateString() %>
                                            </span>
                                            <span class="flex items-center">
                                                <i class="ri-product-hunt-line mr-1"></i>
                                                Product Review
                                            </span>
                                        </div>

                                        <div class="flex items-center space-x-2">
                                            <button
                                                class="text-blue-600 hover:text-blue-700 text-sm font-medium hover:bg-blue-50 px-3 py-1 rounded-lg transition-all duration-200">
                                                <i class="ri-reply-line mr-1"></i>Reply
                                            </button>
                                            <button
                                                class="text-neutral-600 hover:text-neutral-700 text-sm font-medium hover:bg-neutral-100 px-3 py-1 rounded-lg transition-all duration-200">
                                                <i class="ri-flag-line mr-1"></i>Report
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% } %>
                </div>

                <!-- Pagination -->
                <div class="px-6 py-4 border-t border-neutral-200 bg-neutral-50">
                    <div class="flex items-center justify-between">
                        <div class="text-sm text-neutral-700">
                            Showing <span class="font-medium">1</span> to <span class="font-medium">
                                <%= reviewArray.length %>
                            </span> of
                            <span class="font-medium">
                                <%= reviewArray.length %>
                            </span> reviews
                        </div>
                        <nav class="flex items-center space-x-2">
                            <button
                                class="px-3 py-2 text-neutral-500 hover:text-primary-600 transition-colors duration-200"
                                disabled>
                                <i class="ri-arrow-left-line"></i>
                            </button>
                            <button class="px-3 py-2 bg-primary-600 text-white rounded-lg">1</button>
                            <button
                                class="px-3 py-2 text-neutral-500 hover:text-primary-600 transition-colors duration-200"
                                disabled>
                                <i class="ri-arrow-right-line"></i>
                            </button>
                        </nav>
                    </div>
                </div>
            </div>

            <% } else { %>
                <!-- Empty State -->
                <div class="bg-white rounded-xl shadow-lg p-12 text-center border border-neutral-200">
                    <div class="w-24 h-24 bg-neutral-100 rounded-full flex items-center justify-center mx-auto mb-6">
                        <i class="ri-chat-3-line text-4xl text-neutral-400"></i>
                    </div>
                    <h3 class="text-xl font-semibold text-neutral-900 mb-2">No reviews yet</h3>
                    <p class="text-neutral-600 mb-6 max-w-md mx-auto">
                        Your products don't have any reviews yet. Encourage customers to leave reviews to build trust
                        and improve your sales.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-3 justify-center">
                        <a href="/vendors/products"
                            class="inline-flex items-center space-x-2 bg-primary-600 hover:bg-primary-700 text-white px-6 py-3 rounded-lg font-semibold transition-all duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2">
                            <i class="ri-add-line"></i>
                            <span>Add More Products</span>
                        </a>
                        <button
                            class="inline-flex items-center space-x-2 bg-white border border-neutral-300 text-neutral-700 px-6 py-3 rounded-lg font-semibold hover:bg-neutral-50 transition-all duration-200">
                            <i class="ri-mail-line"></i>
                            <span>Request Reviews</span>
                        </button>
                    </div>
                </div>
                <% } %>
    </div>

    <%- include('../partials/vendorFooter.ejs') %>