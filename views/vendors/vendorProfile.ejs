<%- include('../partials/vendorHead.ejs') %>

    <!-- Vendor Profile Content -->
    <div class="min-h-screen bg-gradient-to-br from-primary-50 via-white to-primary-100 py-12">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Profile Header -->
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-neutral-200">
                <!-- Cover Background -->
                <div class="h-32 bg-gradient-to-r from-primary-600 to-primary-700"></div>

                <!-- Profile Info -->
                <div class="relative px-6 pb-6">
                    <!-- Profile Picture -->
                    <div class="flex items-end justify-between -mt-16 mb-4">
                        <div class="relative">
                            <% const vendorProfileImageUrl=getProfileImageUrl(vendor); const
                                vendorIsDefaultImage=vendorProfileImageUrl==='/images/default.jpg' ; %>
                                <% if (!vendorIsDefaultImage) { %>
                                    <img src="<%= vendorProfileImageUrl %>" alt="<%= vendor.name %>"
                                        class="w-32 h-32 rounded-full border-4 border-white shadow-lg object-cover">
                                    <% } else { %>
                                        <div
                                            class="w-32 h-32 rounded-full border-4 border-white shadow-lg bg-primary-600 flex items-center justify-center">
                                            <span class="text-4xl font-bold text-white">
                                                <%= vendor.name ? vendor.name.charAt(0).toUpperCase() : 'V' %>
                                            </span>
                                        </div>
                                        <% } %>
                                            <div
                                                class="absolute bottom-2 right-2 w-6 h-6 bg-green-500 rounded-full border-2 border-white">
                                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="flex space-x-3 mt-16">
                            <a href="/vendors/edit"
                                class="bg-primary-600 hover:bg-primary-700 text-white px-6 py-2 rounded-lg font-medium transition-colors duration-200 flex items-center">
                                <i class="ri-edit-line mr-2"></i>
                                Edit Profile
                            </a>
                            <button onclick="showDeleteModal()"
                                class="bg-red-600 hover:bg-red-700 text-white px-6 py-2 rounded-lg font-medium transition-colors duration-200 flex items-center">
                                <i class="ri-delete-bin-line mr-2"></i>
                                Delete Account
                            </button>
                        </div>
                    </div>

                    <!-- Vendor Details -->
                    <div class="space-y-2">
                        <h1 class="text-3xl font-bold text-neutral-900">
                            <%= vendor.name || 'Vendor Name' %>
                        </h1>
                        <p class="text-neutral-600 flex items-center">
                            <i class="ri-mail-line mr-2 text-primary-600"></i>
                            <%= vendor.email %>
                        </p>
                        <p class="text-sm text-neutral-500 flex items-center">
                            <i class="ri-store-line mr-2 text-primary-600"></i>
                            Vendor since <%= new Date().getFullYear() %>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Profile Details Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-8">
                <!-- Business Information -->
                <div class="lg:col-span-2 space-y-6">
                    <!-- About Section -->
                    <div class="bg-white rounded-xl shadow-lg p-6 border border-neutral-200">
                        <h3 class="text-lg font-semibold text-neutral-900 mb-4 flex items-center">
                            <i class="ri-store-line mr-2 text-primary-600"></i>
                            Business Information
                        </h3>
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-neutral-700 mb-1">Business Name</label>
                                <p class="text-neutral-900 bg-neutral-50 px-4 py-3 rounded-lg">
                                    <%= vendor.name || 'Not provided' %>
                                </p>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-neutral-700 mb-1">Email Address</label>
                                <p class="text-neutral-900 bg-neutral-50 px-4 py-3 rounded-lg flex items-center">
                                    <i class="ri-mail-line mr-2 text-primary-600"></i>
                                    <%= vendor.email %>
                                </p>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-neutral-700 mb-1">Description</label>
                                <p class="text-neutral-900 bg-neutral-50 px-4 py-3 rounded-lg min-h-[100px]">
                                    <%= vendor.description
                                        || 'No description provided yet. Click "Edit Profile" to add a description about your business.'
                                        %>
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Products Section -->
                    <div class="bg-white rounded-xl shadow-lg p-6 border border-neutral-200">
                        <h3 class="text-lg font-semibold text-neutral-900 mb-4 flex items-center">
                            <i class="ri-shopping-bag-line mr-2 text-primary-600"></i>
                            Products (<%= vendor.productList ? vendor.productList.length : 0 %>)
                        </h3>
                        <% if (vendor.productList && vendor.productList.length> 0) { %>
                            <div class="space-y-3">
                                <% vendor.productList.slice(0, 5).forEach(function(product) { %>
                                    <div class="flex items-center justify-between p-3 bg-neutral-50 rounded-lg">
                                        <div class="flex items-center">
                                            <div class="w-2 h-2 bg-primary-600 rounded-full mr-3"></div>
                                            <span class="text-neutral-900 font-medium">
                                                <%= product.name %>
                                            </span>
                                        </div>
                                        <i class="ri-arrow-right-line text-neutral-400"></i>
                                    </div>
                                    <% }); %>
                                        <% if (vendor.productList.length> 5) { %>
                                            <div class="text-center pt-2">
                                                <a href="/vendors/products"
                                                    class="text-primary-600 hover:text-primary-700 font-medium text-sm">
                                                    View all <%= vendor.productList.length %> products →
                                                </a>
                                            </div>
                                            <% } %>
                            </div>
                            <% } else { %>
                                <div class="text-center py-8">
                                    <i class="ri-shopping-bag-line text-4xl text-neutral-300 mb-3"></i>
                                    <p class="text-neutral-500 mb-4">No products added yet</p>
                                    <a href="/products/new"
                                        class="bg-primary-600 hover:bg-primary-700 text-white px-4 py-2 rounded-lg font-medium transition-colors duration-200">
                                        Add Your First Product
                                    </a>
                                </div>
                                <% } %>
                    </div>
                </div>

                <!-- Quick Stats -->
                <div class="space-y-6">
                    <!-- Stats Card -->
                    <div class="bg-white rounded-xl shadow-lg p-6 border border-neutral-200">
                        <h3 class="text-lg font-semibold text-neutral-900 mb-4 flex items-center">
                            <i class="ri-bar-chart-line mr-2 text-primary-600"></i>
                            Quick Stats
                        </h3>
                        <div class="space-y-4">
                            <div class="flex items-center justify-between">
                                <span class="text-neutral-600">Total Products</span>
                                <span class="font-bold text-primary-600">
                                    <%= vendor.productList ? vendor.productList.length : 0 %>
                                </span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-neutral-600">Account Status</span>
                                <span
                                    class="bg-green-100 text-green-800 px-2 py-1 rounded-full text-xs font-medium">Active</span>
                            </div>
                        </div>
                    </div>

                    <!-- Quick Actions -->
                    <div class="bg-white rounded-xl shadow-lg p-6 border border-neutral-200">
                        <h3 class="text-lg font-semibold text-neutral-900 mb-4 flex items-center">
                            <i class="ri-settings-line mr-2 text-primary-600"></i>
                            Quick Actions
                        </h3>
                        <div class="space-y-3">
                            <a href="/products/new"
                                class="w-full bg-primary-600 hover:bg-primary-700 text-white px-4 py-3 rounded-lg font-medium transition-colors duration-200 flex items-center justify-center">
                                <i class="ri-add-line mr-2"></i>
                                Add Product
                            </a>
                            <a href="/vendors/products"
                                class="w-full bg-neutral-100 hover:bg-neutral-200 text-neutral-700 px-4 py-3 rounded-lg font-medium transition-colors duration-200 flex items-center justify-center">
                                <i class="ri-shopping-bag-line mr-2"></i>
                                Manage Products
                            </a>
                            <a href="/vendors/orders"
                                class="w-full bg-neutral-100 hover:bg-neutral-200 text-neutral-700 px-4 py-3 rounded-lg font-medium transition-colors duration-200 flex items-center justify-center">
                                <i class="ri-file-list-line mr-2"></i>
                                View Orders
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Account Modal -->
    <div id="deleteModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-xl max-w-md w-full p-6">
            <div class="text-center">
                <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="ri-error-warning-line text-2xl text-red-600"></i>
                </div>
                <h3 class="text-lg font-semibold text-neutral-900 mb-2">Delete Account</h3>
                <p class="text-neutral-600 mb-6">Are you sure you want to delete your vendor account? This action cannot
                    be undone and will remove all your products.</p>
                <div class="flex space-x-3">
                    <button onclick="hideDeleteModal()"
                        class="flex-1 bg-neutral-100 hover:bg-neutral-200 text-neutral-700 px-4 py-2 rounded-lg font-medium transition-colors duration-200">
                        Cancel
                    </button>
                    <form action="/vendors?_method=delete" method="post" class="flex-1">
                        <button type="submit"
                            class="w-full bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg font-medium transition-colors duration-200">
                            Delete Account
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        function showDeleteModal() {
            document.getElementById('deleteModal').classList.remove('hidden');
        }

        function hideDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
        }

        // Close modal when clicking outside
        document.getElementById('deleteModal').addEventListener('click', function (e) {
            if (e.target === this) {
                hideDeleteModal();
            }
        });
    </script>

    <%- include('../partials/vendorFooter.ejs') %>