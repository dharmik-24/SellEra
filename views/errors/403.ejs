<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Access Forbidden - SellEra</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

        * {
            font-family: 'Inter', sans-serif;
        }

        .lock-animation {
            animation: lockShake 0.6s ease-in-out infinite alternate;
        }

        @keyframes lockShake {
            0% {
                transform: rotate(-2deg);
            }

            100% {
                transform: rotate(2deg);
            }
        }

        .gradient-text {
            background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .slide-up {
            animation: slideUp 0.6s ease-out;
        }

        @keyframes slideUp {
            from {
                transform: translateY(30px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .bounce-in {
            animation: bounceIn 0.8s ease-out;
        }

        @keyframes bounceIn {
            0% {
                transform: scale(0.3);
                opacity: 0;
            }

            50% {
                transform: scale(1.05);
            }

            70% {
                transform: scale(0.9);
            }

            100% {
                transform: scale(1);
                opacity: 1;
            }
        }

        .glow-effect {
            box-shadow: 0 0 20px rgba(245, 158, 11, 0.3);
            animation: glow 2s ease-in-out infinite alternate;
        }

        @keyframes glow {
            from {
                box-shadow: 0 0 20px rgba(245, 158, 11, 0.3);
            }

            to {
                box-shadow: 0 0 30px rgba(245, 158, 11, 0.6);
            }
        }
    </style>
</head>

<body class="min-h-screen bg-gradient-to-br from-purple-50 via-white to-purple-50">
    <!-- Navigation -->
    <nav class="bg-white shadow-sm border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center">
                    <a href="/" class="flex items-center space-x-2">
                        <div
                            class="w-8 h-8 bg-gradient-to-br from-purple-600 to-purple-600 rounded-lg flex items-center justify-center">
                            <i class="ri-shopping-bag-3-line text-white text-lg"></i>
                        </div>
                        <span class="text-xl font-bold text-gray-900">SellEra</span>
                    </a>
                </div>
                <div class="flex items-center space-x-4">
                    <a href="/" class="text-gray-600 hover:text-yellow-600 transition-colors duration-200">
                        <i class="ri-home-line mr-1"></i>Home
                    </a>
                    <a href="/login-register"
                        class="text-gray-600 hover:text-yellow-600 transition-colors duration-200">
                        <i class="ri-login-circle-line mr-1"></i>Login
                    </a>
                    <a href="/contact" class="text-gray-600 hover:text-yellow-600 transition-colors duration-200">
                        <i class="ri-customer-service-line mr-1"></i>Support
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Error Content -->
    <main class="flex-1 flex items-center justify-center px-4 py-16">
        <div class="max-w-4xl mx-auto text-center">
            <!-- Error Illustration -->
            <div class="lock-animation mb-8">
                <div class="relative inline-block">
                    <!-- Large 403 Text -->
                    <div class="text-9xl md:text-[12rem] font-black gradient-text opacity-20 select-none">
                        403
                    </div>

                    <!-- Floating Lock Icon -->
                    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
                        <div
                            class="w-24 h-24 bg-white rounded-full shadow-2xl flex items-center justify-center bounce-in glow-effect">
                            <i class="ri-lock-line text-4xl text-yellow-600"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Error Message -->
            <div class="slide-up mb-8">
                <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
                    Access Forbidden
                </h1>
                <p class="text-xl text-gray-600 mb-2">
                    You don't have permission to access this resource.
                </p>
                <p class="text-lg text-gray-500">
                    This area is restricted and requires special authorization.
                </p>
            </div>

            <!-- Access Information -->
            <div class="slide-up mb-12" style="animation-delay: 0.2s;">
                <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 max-w-2xl mx-auto">
                    <div class="flex items-center mb-4">
                        <i class="ri-shield-line text-yellow-600 text-xl mr-2"></i>
                        <h2 class="text-lg font-semibold text-yellow-800">Why am I seeing this?</h2>
                    </div>
                    <div class="text-yellow-700 text-left space-y-3">
                        <p>This could happen for several reasons:</p>
                        <ul class="space-y-2">
                            <li class="flex items-start">
                                <i class="ri-arrow-right-s-line mr-2 mt-0.5"></i>
                                <span>You're not logged in to your account</span>
                            </li>
                            <li class="flex items-start">
                                <i class="ri-arrow-right-s-line mr-2 mt-0.5"></i>
                                <span>Your account doesn't have the required permissions</span>
                            </li>
                            <li class="flex items-start">
                                <i class="ri-arrow-right-s-line mr-2 mt-0.5"></i>
                                <span>This is a vendor-only or admin-only area</span>
                            </li>
                            <li class="flex items-start">
                                <i class="ri-arrow-right-s-line mr-2 mt-0.5"></i>
                                <span>Your session has expired</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="slide-up grid grid-cols-1 md:grid-cols-3 gap-6 mb-12" style="animation-delay: 0.4s;">
                <a href="/login-register"
                    class="group bg-white rounded-xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 hover:border-blue-200">
                    <div
                        class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-blue-200 transition-colors duration-300">
                        <i class="ri-login-circle-line text-2xl text-blue-600"></i>
                    </div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-2">Sign In</h3>
                    <p class="text-gray-600 text-sm">Log in to your account to access this content</p>
                </a>

                <a href="/"
                    class="group bg-white rounded-xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 hover:border-green-200">
                    <div
                        class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-green-200 transition-colors duration-300">
                        <i class="ri-home-line text-2xl text-green-600"></i>
                    </div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-2">Go Home</h3>
                    <p class="text-gray-600 text-sm">Return to our homepage and browse freely</p>
                </a>

                <a href="/contact"
                    class="group bg-white rounded-xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 hover:border-purple-200">
                    <div
                        class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-purple-200 transition-colors duration-300">
                        <i class="ri-customer-service-line text-2xl text-purple-600"></i>
                    </div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-2">Request Access</h3>
                    <p class="text-gray-600 text-sm">Contact us if you believe this is an error</p>
                </a>
            </div>

            <!-- Account Types Information -->
            <div class="slide-up" style="animation-delay: 0.6s;">
                <h3 class="text-xl font-semibold text-gray-800 mb-6">Account Types & Permissions</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
                    <!-- Customer Account -->
                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4 mx-auto">
                            <i class="ri-user-line text-2xl text-blue-600"></i>
                        </div>
                        <h4 class="text-lg font-semibold text-gray-900 mb-2">Customer</h4>
                        <ul class="text-sm text-gray-600 space-y-1">
                            <li class="flex items-center">
                                <i class="ri-check-line text-green-500 mr-2"></i>
                                Browse products
                            </li>
                            <li class="flex items-center">
                                <i class="ri-check-line text-green-500 mr-2"></i>
                                Make purchases
                            </li>
                            <li class="flex items-center">
                                <i class="ri-check-line text-green-500 mr-2"></i>
                                Write reviews
                            </li>
                            <li class="flex items-center">
                                <i class="ri-check-line text-green-500 mr-2"></i>
                                Manage orders
                            </li>
                        </ul>
                    </div>

                    <!-- Vendor Account -->
                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center mb-4 mx-auto">
                            <i class="ri-store-line text-2xl text-yellow-600"></i>
                        </div>
                        <h4 class="text-lg font-semibold text-gray-900 mb-2">Vendor</h4>
                        <ul class="text-sm text-gray-600 space-y-1">
                            <li class="flex items-center">
                                <i class="ri-check-line text-green-500 mr-2"></i>
                                Manage products
                            </li>
                            <li class="flex items-center">
                                <i class="ri-check-line text-green-500 mr-2"></i>
                                Process orders
                            </li>
                            <li class="flex items-center">
                                <i class="ri-check-line text-green-500 mr-2"></i>
                                View analytics
                            </li>
                            <li class="flex items-center">
                                <i class="ri-check-line text-green-500 mr-2"></i>
                                Vendor dashboard
                            </li>
                        </ul>
                    </div>

                    <!-- Admin Account -->
                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-4 mx-auto">
                            <i class="ri-admin-line text-2xl text-red-600"></i>
                        </div>
                        <h4 class="text-lg font-semibold text-gray-900 mb-2">Admin</h4>
                        <ul class="text-sm text-gray-600 space-y-1">
                            <li class="flex items-center">
                                <i class="ri-check-line text-green-500 mr-2"></i>
                                Full system access
                            </li>
                            <li class="flex items-center">
                                <i class="ri-check-line text-green-500 mr-2"></i>
                                User management
                            </li>
                            <li class="flex items-center">
                                <i class="ri-check-line text-green-500 mr-2"></i>
                                System settings
                            </li>
                            <li class="flex items-center">
                                <i class="ri-check-line text-green-500 mr-2"></i>
                                All reports
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-50 border-t border-gray-200 py-8">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <p class="text-gray-600">
                © 2024 SellEra. All rights reserved. |
                <a href="/privacy" class="text-yellow-600 hover:text-yellow-700">Privacy Policy</a> |
                <a href="/terms" class="text-yellow-600 hover:text-yellow-700">Terms of Service</a>
            </p>
        </div>
    </footer>

    <!-- JavaScript -->
    <script>
        // Check if user is logged in and redirect accordingly
        function checkAuthStatus() {
            // In a real application, you would check the user's authentication status
            // For now, we'll just provide helpful guidance
            console.log('Checking authentication status...');
        }

        // Auto-redirect to login if coming from a protected route
        function handleAutoRedirect() {
            const urlParams = new URLSearchParams(window.location.search);
            const returnUrl = urlParams.get('return');

            if (returnUrl) {
                // Store the return URL for after login
                sessionStorage.setItem('returnUrl', returnUrl);

                // Show a message about automatic redirect
                const message = document.createElement('div');
                message.className = 'fixed top-4 right-4 bg-blue-100 border border-blue-200 text-blue-800 px-4 py-3 rounded-lg shadow-lg z-50';
                message.innerHTML = `
                    <div class="flex items-center">
                        <i class="ri-information-line mr-2"></i>
                        <span>You'll be redirected back after signing in</span>
                    </div>
                `;
                document.body.appendChild(message);

                // Remove message after 5 seconds
                setTimeout(() => {
                    message.remove();
                }, 5000);
            }
        }

        // Initialize page
        document.addEventListener('DOMContentLoaded', function () {
            checkAuthStatus();
            handleAutoRedirect();
        });
    </script>
</body>

</html>