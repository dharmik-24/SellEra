<%- include('../partials/head.ejs') %>

<!-- Error Pages Showcase -->
<main class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50">
    <!-- Header -->
    <section class="bg-white shadow-sm border-b border-gray-200 py-8">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center">
                <h1 class="text-4xl font-bold text-gray-900 mb-4">
                    SellEra Error Pages Showcase
                </h1>
                <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                    Exceptional error handling with beautiful, user-friendly error pages that maintain brand consistency and provide helpful guidance.
                </p>
            </div>
        </div>
    </section>

    <!-- Loading Page Demo -->
    <section class="py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold text-gray-900 mb-4">Premium Loading Experience</h2>
                <p class="text-gray-600 max-w-2xl mx-auto">
                    Animated loading screen with progress indicators and smooth transitions
                </p>
            </div>
            
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden max-w-4xl mx-auto">
                <div class="bg-gradient-to-r from-blue-600 to-purple-600 px-6 py-4">
                    <h3 class="text-white font-semibold flex items-center">
                        <i class="ri-loader-line mr-2"></i>
                        Loading Page
                    </h3>
                </div>
                <div class="p-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
                        <div>
                            <h4 class="text-xl font-semibold text-gray-900 mb-4">Features:</h4>
                            <ul class="space-y-3 text-gray-700">
                                <li class="flex items-center">
                                    <i class="ri-check-line text-green-600 mr-3"></i>
                                    Animated gradient background
                                </li>
                                <li class="flex items-center">
                                    <i class="ri-check-line text-green-600 mr-3"></i>
                                    Floating orbs animation
                                </li>
                                <li class="flex items-center">
                                    <i class="ri-check-line text-green-600 mr-3"></i>
                                    Progress bar with percentage
                                </li>
                                <li class="flex items-center">
                                    <i class="ri-check-line text-green-600 mr-3"></i>
                                    Dynamic loading messages
                                </li>
                                <li class="flex items-center">
                                    <i class="ri-check-line text-green-600 mr-3"></i>
                                    Smooth transitions
                                </li>
                            </ul>
                        </div>
                        <div class="text-center">
                            <a href="/errors/loading" target="_blank" 
                               class="inline-flex items-center bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 transform hover:scale-105 shadow-lg hover:shadow-xl">
                                <i class="ri-external-link-line mr-2"></i>
                                View Loading Page
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Error Pages Grid -->
    <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold text-gray-900 mb-4">Error Pages Collection</h2>
                <p class="text-gray-600 max-w-2xl mx-auto">
                    Comprehensive error handling with custom pages for every scenario
                </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- 404 Error -->
                <div class="bg-gradient-to-br from-blue-50 to-purple-50 rounded-xl p-6 border border-blue-200 hover:shadow-lg transition-all duration-300">
                    <div class="text-center mb-6">
                        <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="ri-search-line text-2xl text-blue-600"></i>
                        </div>
                        <h3 class="text-2xl font-bold text-blue-900 mb-2">404 - Not Found</h3>
                        <p class="text-blue-700">Page doesn't exist</p>
                    </div>
                    <div class="space-y-3">
                        <div class="flex items-center text-sm text-blue-700">
                            <i class="ri-check-line text-blue-600 mr-2"></i>
                            Search functionality
                        </div>
                        <div class="flex items-center text-sm text-blue-700">
                            <i class="ri-check-line text-blue-600 mr-2"></i>
                            Popular categories
                        </div>
                        <div class="flex items-center text-sm text-blue-700">
                            <i class="ri-check-line text-blue-600 mr-2"></i>
                            Quick navigation
                        </div>
                    </div>
                    <div class="mt-6 space-y-2">
                        <a href="/errors/pages/404" target="_blank" 
                           class="w-full bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 inline-block text-center">
                            View Page
                        </a>
                        <a href="/errors/test/404" target="_blank" 
                           class="w-full bg-blue-100 hover:bg-blue-200 text-blue-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 inline-block text-center">
                            Test Error
                        </a>
                    </div>
                </div>

                <!-- 500 Error -->
                <div class="bg-gradient-to-br from-red-50 to-orange-50 rounded-xl p-6 border border-red-200 hover:shadow-lg transition-all duration-300">
                    <div class="text-center mb-6">
                        <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="ri-error-warning-line text-2xl text-red-600"></i>
                        </div>
                        <h3 class="text-2xl font-bold text-red-900 mb-2">500 - Server Error</h3>
                        <p class="text-red-700">Internal server error</p>
                    </div>
                    <div class="space-y-3">
                        <div class="flex items-center text-sm text-red-700">
                            <i class="ri-check-line text-red-600 mr-2"></i>
                            System status info
                        </div>
                        <div class="flex items-center text-sm text-red-700">
                            <i class="ri-check-line text-red-600 mr-2"></i>
                            Auto-retry functionality
                        </div>
                        <div class="flex items-center text-sm text-red-700">
                            <i class="ri-check-line text-red-600 mr-2"></i>
                            Error reporting
                        </div>
                    </div>
                    <div class="mt-6 space-y-2">
                        <a href="/errors/pages/500" target="_blank" 
                           class="w-full bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 inline-block text-center">
                            View Page
                        </a>
                        <a href="/errors/test/500" target="_blank" 
                           class="w-full bg-red-100 hover:bg-red-200 text-red-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 inline-block text-center">
                            Test Error
                        </a>
                    </div>
                </div>

                <!-- 403 Error -->
                <div class="bg-gradient-to-br from-yellow-50 to-orange-50 rounded-xl p-6 border border-yellow-200 hover:shadow-lg transition-all duration-300">
                    <div class="text-center mb-6">
                        <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="ri-lock-line text-2xl text-yellow-600"></i>
                        </div>
                        <h3 class="text-2xl font-bold text-yellow-900 mb-2">403 - Forbidden</h3>
                        <p class="text-yellow-700">Access denied</p>
                    </div>
                    <div class="space-y-3">
                        <div class="flex items-center text-sm text-yellow-700">
                            <i class="ri-check-line text-yellow-600 mr-2"></i>
                            Account type info
                        </div>
                        <div class="flex items-center text-sm text-yellow-700">
                            <i class="ri-check-line text-yellow-600 mr-2"></i>
                            Login prompts
                        </div>
                        <div class="flex items-center text-sm text-yellow-700">
                            <i class="ri-check-line text-yellow-600 mr-2"></i>
                            Permission explanations
                        </div>
                    </div>
                    <div class="mt-6 space-y-2">
                        <a href="/errors/pages/403" target="_blank" 
                           class="w-full bg-yellow-600 hover:bg-yellow-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 inline-block text-center">
                            View Page
                        </a>
                        <a href="/errors/test/403" target="_blank" 
                           class="w-full bg-yellow-100 hover:bg-yellow-200 text-yellow-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 inline-block text-center">
                            Test Error
                        </a>
                    </div>
                </div>

                <!-- Generic Error -->
                <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-xl p-6 border border-gray-200 hover:shadow-lg transition-all duration-300">
                    <div class="text-center mb-6">
                        <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="ri-alert-line text-2xl text-gray-600"></i>
                        </div>
                        <h3 class="text-2xl font-bold text-gray-900 mb-2">Generic Error</h3>
                        <p class="text-gray-700">Flexible error template</p>
                    </div>
                    <div class="space-y-3">
                        <div class="flex items-center text-sm text-gray-700">
                            <i class="ri-check-line text-gray-600 mr-2"></i>
                            Dynamic theming
                        </div>
                        <div class="flex items-center text-sm text-gray-700">
                            <i class="ri-check-line text-gray-600 mr-2"></i>
                            Configurable content
                        </div>
                        <div class="flex items-center text-sm text-gray-700">
                            <i class="ri-check-line text-gray-600 mr-2"></i>
                            Multiple error codes
                        </div>
                    </div>
                    <div class="mt-6 space-y-2">
                        <a href="/errors/pages/error?code=400" target="_blank" 
                           class="w-full bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 inline-block text-center">
                            View Page
                        </a>
                        <a href="/errors/test/400" target="_blank" 
                           class="w-full bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 inline-block text-center">
                            Test Error
                        </a>
                    </div>
                </div>

                <!-- More Error Types -->
                <div class="bg-gradient-to-br from-purple-50 to-pink-50 rounded-xl p-6 border border-purple-200 hover:shadow-lg transition-all duration-300">
                    <div class="text-center mb-6">
                        <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="ri-time-line text-2xl text-purple-600"></i>
                        </div>
                        <h3 class="text-2xl font-bold text-purple-900 mb-2">429 - Rate Limited</h3>
                        <p class="text-purple-700">Too many requests</p>
                    </div>
                    <div class="space-y-3">
                        <div class="flex items-center text-sm text-purple-700">
                            <i class="ri-check-line text-purple-600 mr-2"></i>
                            Rate limit info
                        </div>
                        <div class="flex items-center text-sm text-purple-700">
                            <i class="ri-check-line text-purple-600 mr-2"></i>
                            Retry guidance
                        </div>
                        <div class="flex items-center text-sm text-purple-700">
                            <i class="ri-check-line text-purple-600 mr-2"></i>
                            Wait time display
                        </div>
                    </div>
                    <div class="mt-6 space-y-2">
                        <a href="/errors/pages/error?code=429" target="_blank" 
                           class="w-full bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 inline-block text-center">
                            View Page
                        </a>
                        <a href="/errors/test/429" target="_blank" 
                           class="w-full bg-purple-100 hover:bg-purple-200 text-purple-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 inline-block text-center">
                            Test Error
                        </a>
                    </div>
                </div>

                <!-- Service Unavailable -->
                <div class="bg-gradient-to-br from-indigo-50 to-blue-50 rounded-xl p-6 border border-indigo-200 hover:shadow-lg transition-all duration-300">
                    <div class="text-center mb-6">
                        <div class="w-16 h-16 bg-indigo-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="ri-tools-line text-2xl text-indigo-600"></i>
                        </div>
                        <h3 class="text-2xl font-bold text-indigo-900 mb-2">503 - Unavailable</h3>
                        <p class="text-indigo-700">Service maintenance</p>
                    </div>
                    <div class="space-y-3">
                        <div class="flex items-center text-sm text-indigo-700">
                            <i class="ri-check-line text-indigo-600 mr-2"></i>
                            Maintenance info
                        </div>
                        <div class="flex items-center text-sm text-indigo-700">
                            <i class="ri-check-line text-indigo-600 mr-2"></i>
                            Estimated downtime
                        </div>
                        <div class="flex items-center text-sm text-indigo-700">
                            <i class="ri-check-line text-indigo-600 mr-2"></i>
                            Status updates
                        </div>
                    </div>
                    <div class="mt-6 space-y-2">
                        <a href="/errors/pages/error?code=503" target="_blank" 
                           class="w-full bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 inline-block text-center">
                            View Page
                        </a>
                        <a href="/errors/test/503" target="_blank" 
                           class="w-full bg-indigo-100 hover:bg-indigo-200 text-indigo-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 inline-block text-center">
                            Test Error
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="py-16 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold text-gray-900 mb-4">Key Features</h2>
                <p class="text-gray-600 max-w-2xl mx-auto">
                    Our error pages are designed with user experience and brand consistency in mind
                </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                <div class="text-center">
                    <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="ri-palette-line text-2xl text-blue-600"></i>
                    </div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-2">Brand Consistent</h3>
                    <p class="text-gray-600 text-sm">Maintains SellEra's visual identity and color scheme</p>
                </div>
                
                <div class="text-center">
                    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="ri-smartphone-line text-2xl text-green-600"></i>
                    </div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-2">Mobile Responsive</h3>
                    <p class="text-gray-600 text-sm">Optimized for all devices and screen sizes</p>
                </div>
                
                <div class="text-center">
                    <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="ri-user-heart-line text-2xl text-purple-600"></i>
                    </div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-2">User Friendly</h3>
                    <p class="text-gray-600 text-sm">Clear messaging and helpful recovery options</p>
                </div>
                
                <div class="text-center">
                    <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="ri-magic-line text-2xl text-yellow-600"></i>
                    </div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-2">Interactive</h3>
                    <p class="text-gray-600 text-sm">Smooth animations and engaging interactions</p>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('../partials/footer.ejs') %>
