<%- include('../partials/head.ejs') %>

    <!-- Modern Product Details Page -->
    <main class="min-h-screen bg-neutral-50">
        <!-- Breadcrumb Navigation -->
        <section class="bg-white border-b border-neutral-200 py-4">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <nav class="flex items-center space-x-2 text-sm text-neutral-600">
                    <a href="/" class="hover:text-primary-600 transition-colors duration-200">
                        <i class="ri-home-line"></i>
                        <span class="ml-1">Home</span>
                    </a>
                    <i class="ri-arrow-right-s-line text-neutral-400"></i>
                    <a href="/products" class="hover:text-primary-600 transition-colors duration-200">Products</a>
                    <i class="ri-arrow-right-s-line text-neutral-400"></i>
                    <span class="text-neutral-900 font-medium">
                        <%= product.name %>
                    </span>
                </nav>
            </div>
        </section>

        <!-- Product Details Section -->
        <section class="py-12">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                    <!-- Product Image -->
                    <div class="space-y-6">
                        <div
                            class="aspect-square bg-white rounded-2xl shadow-lg overflow-hidden border border-neutral-200">
                            <% const imageUrls=getProductImageUrls(product); const mainImageUrl=imageUrls[0]; const
                                isDefaultImage=mainImageUrl==='/images/default.jpg' ; %>
                                <% if (!isDefaultImage) { %>
                                    <img id="main-product-image" src="<%= mainImageUrl %>" alt="<%= product.name %>"
                                        class="w-full h-full object-cover hover:scale-105 transition-transform duration-500">
                                    <% } else { %>
                                        <div class="w-full h-full flex items-center justify-center bg-neutral-100">
                                            <div class="text-center">
                                                <i class="ri-image-line text-6xl text-neutral-400 mb-4"></i>
                                                <p class="text-neutral-500 font-medium">No Image Available</p>
                                            </div>
                                        </div>
                                        <% } %>
                        </div>

                        <!-- Image Gallery Thumbnails -->
                        <% if (imageUrls.length> 1 && !isDefaultImage) { %>
                            <div class="grid grid-cols-4 gap-4">
                                <% for(let i=0; i < Math.min(imageUrls.length, 4); i++) { %>
                                    <div class="aspect-square bg-neutral-100 rounded-lg border-2 <%= i === 0 ? 'border-primary-500' : 'border-transparent' %> hover:border-primary-500 cursor-pointer transition-all duration-200"
                                        onclick="changeMainImage('<%= imageUrls[i] %>', this)">
                                        <img src="<%= imageUrls[i] %>" alt="<%= product.name %> - Image <%= i + 1 %>"
                                            class="w-full h-full object-cover rounded-lg thumbnail-image">
                                    </div>
                                    <% } %>

                                        <!-- Show remaining count if more than 4 images -->
                                        <% if (imageUrls.length> 4) { %>
                                            <div
                                                class="aspect-square bg-neutral-100 rounded-lg border-2 border-transparent flex items-center justify-center">
                                                <div class="text-center">
                                                    <span class="text-sm font-semibold text-neutral-600">+<%=
                                                            imageUrls.length - 4 %></span>
                                                    <p class="text-xs text-neutral-500">more</p>
                                                </div>
                                            </div>
                                            <% } %>
                            </div>
                            <% } %>
                    </div>

                    <!-- Product Information -->
                    <div class="space-y-8">
                        <!-- Product Header -->
                        <div class="space-y-4">
                            <div class="flex items-center space-x-2">
                                <span
                                    class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary-100 text-primary-800">
                                    <%= product.category || 'General' %>
                                </span>
                                <% if(product.qty> 0) { %>
                                    <span
                                        class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        <i class="ri-check-line mr-1"></i>In Stock
                                    </span>
                                    <% } else { %>
                                        <span
                                            class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                            <i class="ri-close-line mr-1"></i>Out of Stock
                                        </span>
                                        <% } %>
                            </div>

                            <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 leading-tight">
                                <%= product.name %>
                            </h1>

                            <!-- Rating and Reviews -->
                            <div class="flex items-center space-x-4">
                                <div class="flex items-center space-x-1">
                                    <% for(let i=1; i <=5; i++) { %>
                                        <i class="ri-star-fill text-yellow-400"></i>
                                        <% } %>
                                            <span class="text-sm text-neutral-600 ml-2">(4.8)</span>
                                </div>
                                <span class="text-sm text-neutral-500">•</span>
                                <span class="text-sm text-neutral-600">
                                    <%= review ? review.length : 0 %> reviews
                                </span>
                            </div>
                        </div>

                        <!-- Price Section -->
                        <div class="space-y-2">
                            <div class="flex items-baseline space-x-3">
                                <span class="text-4xl font-bold text-primary-600">₹<%= product.price %></span>
                                <% if(product.sale> 0) { %>
                                    <span class="text-xl text-neutral-500 line-through">₹<%= product.price +
                                            product.sale %></span>
                                    <span
                                        class="inline-flex items-center px-2.5 py-0.5 rounded-full text-sm font-medium bg-red-100 text-red-800">
                                        <%= Math.round((product.sale / (product.price + product.sale)) * 100) %>% OFF
                                    </span>
                                    <% } %>
                            </div>
                            <p class="text-sm text-neutral-600">
                                <i class="ri-truck-line mr-1"></i>Free shipping on orders over ₹500
                            </p>
                        </div>

                        <!-- Product Description -->
                        <div class="space-y-4">
                            <h3 class="text-lg font-semibold text-neutral-900">Description</h3>
                            <p class="text-neutral-700 leading-relaxed">
                                <%= product.description || 'No description available for this product.' %>
                            </p>
                        </div>

                        <!-- Product Features -->
                        <div class="space-y-4">
                            <h3 class="text-lg font-semibold text-neutral-900">Features</h3>
                            <ul class="space-y-2">
                                <li class="flex items-center space-x-3">
                                    <i class="ri-check-line text-green-600"></i>
                                    <span class="text-neutral-700">High-quality materials</span>
                                </li>
                                <li class="flex items-center space-x-3">
                                    <i class="ri-check-line text-green-600"></i>
                                    <span class="text-neutral-700">Fast and reliable shipping</span>
                                </li>
                                <li class="flex items-center space-x-3">
                                    <i class="ri-check-line text-green-600"></i>
                                    <span class="text-neutral-700">30-day return policy</span>
                                </li>
                                <li class="flex items-center space-x-3">
                                    <i class="ri-check-line text-green-600"></i>
                                    <span class="text-neutral-700">Customer support included</span>
                                </li>
                            </ul>
                        </div>

                        <!-- Quantity and Actions -->
                        <div class="space-y-6">
                            <!-- Quantity Selector -->
                            <div class="flex items-center space-x-4">
                                <label class="text-sm font-medium text-neutral-700">Quantity:</label>
                                <div class="flex items-center border border-neutral-300 rounded-lg">
                                    <button class="px-3 py-2 hover:bg-neutral-50 transition-colors duration-200"
                                        onclick="decreaseQuantity()">
                                        <i class="ri-subtract-line"></i>
                                    </button>
                                    <input type="number" id="quantity" value="1" min="1" max="<%= product.qty || 10 %>"
                                        class="w-16 text-center border-0 focus:ring-0 focus:outline-none">
                                    <button class="px-3 py-2 hover:bg-neutral-50 transition-colors duration-200"
                                        onclick="increaseQuantity()">
                                        <i class="ri-add-line"></i>
                                    </button>
                                </div>
                                <span class="text-sm text-neutral-600">(<%= product.qty || 0 %> available)</span>
                            </div>

                            <!-- Action Buttons -->
                            <div class="space-y-4">
                                <% if(isLoggedIn && !isVendor) { %>
                                    <div class="flex flex-col sm:flex-row gap-4">
                                        <a href="/users/cart/<%= product._id %>"
                                            class="flex-1 bg-primary-600 hover:bg-primary-700 text-white px-8 py-4 rounded-lg font-semibold text-center transition-all duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 shadow-lg hover:shadow-xl">
                                            <i class="ri-shopping-cart-line mr-2"></i>Add to Cart
                                        </a>
                                        <button
                                            class="flex-1 bg-white border-2 border-primary-600 text-primary-600 hover:bg-primary-50 px-8 py-4 rounded-lg font-semibold transition-all duration-200">
                                            <i class="ri-heart-line mr-2"></i>Add to Wishlist
                                        </button>
                                    </div>
                                    <a href="/reviews/new/<%= product._id %>"
                                        class="w-full bg-neutral-800 hover:bg-neutral-900 text-white px-8 py-3 rounded-lg font-medium text-center transition-all duration-200 inline-block">
                                        <i class="ri-star-line mr-2"></i>Write a Review
                                    </a>
                                    <% } else if(isVendor) { %>
                                        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                                            <div class="flex items-center space-x-2">
                                                <i class="ri-information-line text-blue-600"></i>
                                                <span class="text-blue-800 font-medium">Vendor View</span>
                                            </div>
                                            <p class="text-blue-700 text-sm mt-1">You are viewing this product as a
                                                vendor.</p>
                                        </div>
                                        <% } else { %>
                                            <div class="space-y-3">
                                                <a href="/login-register"
                                                    class="w-full bg-primary-600 hover:bg-primary-700 text-white px-8 py-4 rounded-lg font-semibold text-center transition-all duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 shadow-lg hover:shadow-xl inline-block">
                                                    <i class="ri-login-circle-line mr-2"></i>Login to Purchase
                                                </a>
                                                <p class="text-sm text-neutral-600 text-center">
                                                    New customer? <a href="/login-register"
                                                        class="text-primary-600 hover:text-primary-700 font-medium">Create
                                                        an account</a>
                                                </p>
                                            </div>
                                            <% } %>
                            </div>
                        </div>

                        <!-- Product Info Cards -->
                        <div class="grid grid-cols-2 gap-4">
                            <div class="bg-white rounded-lg border border-neutral-200 p-4 text-center">
                                <i class="ri-truck-line text-2xl text-primary-600 mb-2"></i>
                                <h4 class="font-medium text-neutral-900">Fast Delivery</h4>
                                <p class="text-sm text-neutral-600">2-3 business days</p>
                            </div>
                            <div class="bg-white rounded-lg border border-neutral-200 p-4 text-center">
                                <i class="ri-shield-check-line text-2xl text-green-600 mb-2"></i>
                                <h4 class="font-medium text-neutral-900">Secure Payment</h4>
                                <p class="text-sm text-neutral-600">100% protected</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Reviews Section -->
        <% if(review && review.length> 0) { %>
            <section class="py-16 bg-white">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <!-- Reviews Header -->
                    <div class="text-center mb-12">
                        <h2 class="text-3xl font-bold text-neutral-900 mb-4">Customer Reviews</h2>
                        <div class="flex items-center justify-center space-x-4">
                            <div class="flex items-center space-x-1">
                                <% for(let i=1; i <=5; i++) { %>
                                    <i class="ri-star-fill text-yellow-400 text-xl"></i>
                                    <% } %>
                            </div>
                            <span class="text-lg font-semibold text-neutral-700">4.8 out of 5</span>
                            <span class="text-neutral-500">•</span>
                            <span class="text-neutral-600">
                                <%= review.length %> reviews
                            </span>
                        </div>
                    </div>

                    <!-- Reviews Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        <% for (let i of review) { %>
                            <div
                                class="bg-neutral-50 rounded-xl p-6 border border-neutral-200 hover:shadow-lg transition-all duration-300 hover:border-primary-200">
                                <!-- Review Header -->
                                <div class="flex items-center space-x-4 mb-4">
                                    <div
                                        class="w-12 h-12 bg-gradient-to-br from-primary-500 to-primary-600 rounded-full flex items-center justify-center text-white font-semibold text-lg">
                                        <%= i.user.name.charAt(0).toUpperCase() %>
                                    </div>
                                    <div class="flex-1">
                                        <h4 class="font-semibold text-neutral-900">
                                            <%= i.user.name %>
                                        </h4>
                                        <div class="flex items-center space-x-1 mt-1">
                                            <% for(let star=1; star <=5; star++) { %>
                                                <i class="ri-star-fill text-yellow-400 text-sm"></i>
                                                <% } %>
                                        </div>
                                    </div>
                                </div>

                                <!-- Review Content -->
                                <p class="text-neutral-700 leading-relaxed mb-4">
                                    "<%= i.review %>"
                                </p>

                                <!-- Review Footer -->
                                <div class="flex items-center justify-between text-sm text-neutral-500">
                                    <span class="flex items-center">
                                        <i class="ri-check-line text-green-600 mr-1"></i>
                                        Verified Purchase
                                    </span>
                                    <span>
                                        <i class="ri-time-line mr-1"></i>
                                        <%= new Date().toLocaleDateString() %>
                                    </span>
                                </div>
                            </div>
                            <% } %>
                    </div>

                    <!-- Load More Reviews Button -->
                    <% if(review.length> 6) { %>
                        <div class="text-center mt-12">
                            <button
                                class="bg-white border-2 border-primary-600 text-primary-600 hover:bg-primary-50 px-8 py-3 rounded-lg font-semibold transition-all duration-200">
                                <i class="ri-arrow-down-line mr-2"></i>Load More Reviews
                            </button>
                        </div>
                        <% } %>
                </div>
            </section>
            <% } %>


    </main>

    <!-- JavaScript for Interactive Features -->
    <script>
        // Quantity selector functions
        function increaseQuantity() {
            const quantityInput = document.getElementById('quantity');
            const currentValue = parseInt(quantityInput.value);
            const maxValue = parseInt(quantityInput.max);

            if (currentValue < maxValue) {
                quantityInput.value = currentValue + 1;
            }
        }

        function decreaseQuantity() {
            const quantityInput = document.getElementById('quantity');
            const currentValue = parseInt(quantityInput.value);
            const minValue = parseInt(quantityInput.min);

            if (currentValue > minValue) {
                quantityInput.value = currentValue - 1;
            }
        }

        // Image gallery functionality
        function changeMainImage(imageSrc, thumbnailElement) {
            const mainImage = document.getElementById('main-product-image');
            if (mainImage) {
                mainImage.src = imageSrc;
            }

            // Update active thumbnail border
            if (thumbnailElement) {
                const thumbnails = document.querySelectorAll('.thumbnail-image');
                thumbnails.forEach(t => t.parentElement.classList.remove('border-primary-500'));
                thumbnailElement.classList.add('border-primary-500');
            }
        }

        // Add to wishlist functionality
        function addToWishlist(productId) {
            // Implementation for wishlist functionality
            console.log('Adding product to wishlist:', productId);

            // Show success message
            const button = event.target;
            const originalText = button.innerHTML;
            button.innerHTML = '<i class="ri-heart-fill mr-2"></i>Added to Wishlist';
            button.classList.add('bg-red-50', 'text-red-600', 'border-red-600');

            setTimeout(() => {
                button.innerHTML = originalText;
                button.classList.remove('bg-red-50', 'text-red-600', 'border-red-600');
            }, 2000);
        }

        // Smooth scroll to reviews
        function scrollToReviews() {
            const reviewsSection = document.querySelector('.reviews-section');
            if (reviewsSection) {
                reviewsSection.scrollIntoView({ behavior: 'smooth' });
            }
        }

        // Initialize page
        document.addEventListener('DOMContentLoaded', function () {
            // Add any initialization code here
            console.log('Product page loaded successfully');

            // Add click handlers for thumbnail images
            const thumbnails = document.querySelectorAll('.thumbnail-image');
            thumbnails.forEach(thumbnail => {
                thumbnail.addEventListener('click', function () {
                    const imageSrc = this.src;
                    changeMainImage(imageSrc);

                    // Update active thumbnail
                    thumbnails.forEach(t => t.parentElement.classList.remove('border-primary-500'));
                    this.parentElement.classList.add('border-primary-500');
                });
            });
        });
    </script>

    <%- include('../partials/footer.ejs') %>