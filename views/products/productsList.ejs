<%- include('../partials/head.ejs') %>

    <!-- Products Listing Page -->
    <main class="min-h-screen bg-neutral-50">
        <!-- Page Header -->
        <section class="bg-gradient-to-r from-primary-600 to-primary-700 text-white py-16">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center">
                    <h1 class="text-3xl md:text-4xl font-bold mb-4">
                        <%= title.name %>
                    </h1>
                    <p class="text-lg text-primary-100 max-w-2xl mx-auto">
                        Discover amazing products from our trusted vendors
                    </p>
                </div>
            </div>
        </section>

        <!-- Filters and Search -->
        <section class="bg-white border-b border-neutral-200 py-6">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <form method="GET" action="/products" class="space-y-4">
                    <div class="flex flex-col md:flex-row md:items-center md:justify-between space-y-4 md:space-y-0">
                        <!-- Search Bar -->
                        <div class="flex-1 max-w-lg">
                            <div class="relative">
                                <input type="text" name="search" placeholder="Search products..."
                                    value="<%= currentFilters.search || '' %>"
                                    class="w-full px-4 py-2 pl-10 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                                <i class="ri-search-line absolute left-3 top-1/2 transform -translate-y-1/2 text-neutral-400"></i>
                            </div>
                        </div>

                        <!-- Filter Options -->
                        <div class="flex items-center space-x-4">
                            <select name="sort" onchange="this.form.submit()"
                                class="px-4 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                                <option value="">Sort by: Featured</option>
                                <option value="price-low" <%= currentFilters.sort === 'price-low' ? 'selected' : '' %>>Price: Low to High</option>
                                <option value="price-high" <%= currentFilters.sort === 'price-high' ? 'selected' : '' %>>Price: High to Low</option>
                                <option value="newest" <%= currentFilters.sort === 'newest' ? 'selected' : '' %>>Newest First</option>
                                <option value="name" <%= currentFilters.sort === 'name' ? 'selected' : '' %>>Name A-Z</option>
                            </select>

                            <button type="button" onclick="toggleFilters()"
                                class="px-4 py-2 bg-neutral-100 hover:bg-neutral-200 text-neutral-700 rounded-lg transition-colors duration-200">
                                <i class="ri-filter-line mr-2"></i>Filters
                            </button>
                        </div>
                    </div>

                    <!-- Advanced Filters (Hidden by default) -->
                    <div id="advancedFilters" class="hidden">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 pt-4 border-t border-neutral-200">
                            <!-- Category Filter -->
                            <div>
                                <label class="block text-sm font-medium text-neutral-700 mb-2">Category</label>
                                <select name="category"
                                    class="w-full px-3 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                                    <option value="">All Categories</option>
                                    <% categories.forEach(cat => { %>
                                        <option value="<%= cat %>" <%= currentFilters.category === cat ? 'selected' : '' %>><%= cat %></option>
                                    <% }); %>
                                </select>
                            </div>

                            <!-- Price Range -->
                            <div>
                                <label class="block text-sm font-medium text-neutral-700 mb-2">Min Price</label>
                                <input type="number" name="minPrice" placeholder="₹0"
                                    value="<%= currentFilters.minPrice || '' %>"
                                    class="w-full px-3 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-neutral-700 mb-2">Max Price</label>
                                <input type="number" name="maxPrice" placeholder="₹10000"
                                    value="<%= currentFilters.maxPrice || '' %>"
                                    class="w-full px-3 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200">
                            </div>

                            <!-- Filter Actions -->
                            <div class="flex items-end space-x-2">
                                <button type="submit"
                                    class="flex-1 bg-primary-600 hover:bg-primary-700 text-white px-4 py-2 rounded-lg font-medium transition-colors duration-200">
                                    Apply
                                </button>
                                <a href="/products"
                                    class="flex-1 text-center bg-neutral-200 hover:bg-neutral-300 text-neutral-700 px-4 py-2 rounded-lg font-medium transition-colors duration-200">
                                    Clear
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </section>

        <!-- Products Grid -->
        <section class="py-12">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <% if(showdata.length > 0) { %>
                    <!-- Products Count -->
                    <div class="mb-8">
                        <p class="text-neutral-600">Showing <%= showdata.length %> products</p>
                    </div>

                    <!-- Products Grid -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                        <% for (let i of showdata) { %>
                            <div class="group bg-white rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 overflow-hidden">
                                <!-- Product Image -->
                                <div class="relative overflow-hidden">
                                    <% const imageUrl = getProductImageUrl(i); %>
                                    <% const isDefaultImage = imageUrl === '/images/default.jpg'; %>
                                    
                                    <% if (!isDefaultImage) { %>
                                        <img src="<%= imageUrl %>" alt="<%= i.name %>" class="w-full h-48 object-cover group-hover:scale-110 transition-transform duration-500">
                                    <% } else { %>
                                        <div class="w-full h-48 bg-neutral-200 flex items-center justify-center">
                                            <i class="ri-image-line text-4xl text-neutral-400"></i>
                                        </div>
                                    <% } %>

                                    <!-- Overlay -->
                                    <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

                                    <!-- Quick Actions -->
                                    <div class="absolute top-4 right-4 space-y-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                        <button class="w-10 h-10 bg-white rounded-full flex items-center justify-center shadow-lg hover:bg-primary-600 hover:text-white transition-colors duration-200">
                                            <i class="ri-heart-line text-lg"></i>
                                        </button>
                                        <a href="/products/<%= i._id %>" class="w-10 h-10 bg-white rounded-full flex items-center justify-center shadow-lg hover:bg-primary-600 hover:text-white transition-colors duration-200">
                                            <i class="ri-eye-line text-lg"></i>
                                        </a>
                                    </div>

                                    <!-- Sale Badge -->
                                    <div class="absolute top-4 left-4">
                                        <span class="bg-accent-600 text-white px-2 py-1 rounded-full text-xs font-semibold">New</span>
                                    </div>
                                </div>

                                <!-- Product Info -->
                                <div class="p-6">
                                    <h3 class="text-lg font-semibold text-neutral-900 mb-2 line-clamp-2">
                                        <%= i.name %>
                                    </h3>

                                    <div class="flex items-center justify-between mb-4">
                                        <span class="text-2xl font-bold text-primary-600">
                                            ₹<%= i.price %>
                                        </span>
                                        <div class="flex items-center space-x-1">
                                            <div class="flex text-yellow-400">
                                                <i class="ri-star-fill text-sm"></i>
                                                <i class="ri-star-fill text-sm"></i>
                                                <i class="ri-star-fill text-sm"></i>
                                                <i class="ri-star-fill text-sm"></i>
                                                <i class="ri-star-line text-sm"></i>
                                            </div>
                                            <span class="text-sm text-neutral-500">(4.0)</span>
                                        </div>
                                    </div>

                                    <!-- Action Buttons -->
                                    <div class="space-y-2">
                                        <a href="/users/cart/<%= i._id %>" class="w-full bg-primary-600 hover:bg-primary-700 text-white py-2 px-4 rounded-lg font-medium transition-all duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 flex items-center justify-center space-x-2">
                                            <i class="ri-shopping-cart-line"></i>
                                            <span>Add to Cart</span>
                                        </a>
                                        <a href="/products/<%= i._id %>" class="w-full border-2 border-primary-600 text-primary-600 hover:bg-primary-600 hover:text-white py-2 px-4 rounded-lg font-medium transition-all duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 flex items-center justify-center space-x-2">
                                            <i class="ri-shopping-bag-line"></i>
                                            <span>Buy Now</span>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        <% } %>
                    </div>

                    <!-- Pagination -->
                    <div class="mt-12 flex justify-center">
                        <nav class="flex items-center space-x-2">
                            <button class="px-3 py-2 text-neutral-500 hover:text-primary-600 transition-colors duration-200">
                                <i class="ri-arrow-left-line"></i>
                            </button>
                            <button class="px-3 py-2 bg-primary-600 text-white rounded-lg">1</button>
                            <button class="px-3 py-2 text-neutral-600 hover:text-primary-600 transition-colors duration-200">2</button>
                            <button class="px-3 py-2 text-neutral-600 hover:text-primary-600 transition-colors duration-200">3</button>
                            <button class="px-3 py-2 text-neutral-500 hover:text-primary-600 transition-colors duration-200">
                                <i class="ri-arrow-right-line"></i>
                            </button>
                        </nav>
                    </div>
                <% } else { %>
                    <!-- Empty State -->
                    <div class="text-center py-16">
                        <div class="w-24 h-24 bg-neutral-200 rounded-full flex items-center justify-center mx-auto mb-6">
                            <i class="ri-shopping-bag-line text-4xl text-neutral-400"></i>
                        </div>
                        <h3 class="text-xl font-semibold text-neutral-900 mb-2">No products found</h3>
                        <p class="text-neutral-600 mb-6">We couldn't find any products matching your criteria.</p>
                        <a href="/" class="inline-flex items-center space-x-2 bg-primary-600 hover:bg-primary-700 text-white px-6 py-3 rounded-lg font-semibold transition-all duration-200 transform hover:scale-105">
                            <i class="ri-home-line"></i>
                            <span>Back to Home</span>
                        </a>
                    </div>
                <% } %>
            </div>
        </section>
    </main>

    <script>
        function toggleFilters() {
            const filters = document.getElementById('advancedFilters');
            filters.classList.toggle('hidden');
        }
    </script>

    <%- include('../partials/footer.ejs') %>
